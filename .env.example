# BankSight Configuration - Development Environment
# Copy this file to .env and update with your configuration

# Application Configuration
DEBUG=True
APP_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=banksight_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/banksight.log

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# Fraud Detection
FRAUD_DETECTION_MODEL=isolation_forest
FRAUD_SCORE_THRESHOLD=0.7
ANOMALY_THRESHOLD=2.5

# Cache Configuration
CACHE_ENABLED=True
CACHE_TTL=3600

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0

# Security
ENCRYPTION_ENABLED=True
ENABLE_AUTH=False

# Feature Flags
ENABLE_FRAUD_DETECTION=True
ENABLE_CUSTOMER_ANALYTICS=True
ENABLE_RISK_SCORING=True
ENABLE_REAL_TIME_MONITORING=True

# Data Paths
DATA_DIR=data
REPORTS_DIR=reports
MODELS_DIR=models

# Email Configuration (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Alert Configuration
ALERT_THRESHOLD_AMOUNT=50000
ALERT_EMAIL_RECIPIENTS=admin@bank.com
